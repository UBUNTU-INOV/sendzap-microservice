# Port to run the server on
PORT=3000

# Secret key required in X-API-KEY header
API_KEY=your_very_secret_key_here

# Laravel Backend Webhook URL
WEBHOOK_URL=https://api.sendzap.click/api/webhooks/whatsapp

# HMAC secret used to sign webhook payloads (X-Webhook-Signature header)
WEBHOOK_SECRET=your_webhook_secret_here

# Logging level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Set to 'production' to disable pino-pretty (raw JSON logs)
# NODE_ENV=production
